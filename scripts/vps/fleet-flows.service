[Unit]
Description=Fleet Flows Next.js
After=network.target postgresql.service

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/var/www/fleet-flows/current
Environment=NODE_ENV=production
# Prefer loading env from file (create on server, chmod 600):
EnvironmentFile=-/var/www/fleet-flows/current/.env.production
ExecStart=/usr/bin/npm run start -- -p 3000
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
